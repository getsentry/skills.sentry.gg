{
  "name": "skills-sentry-dev",
  "version": "1.0.0",
  "description": "Proxy service mapping pretty URLs to raw GitHub markdown for skills.sentry.dev",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@sentry/hono": "^10.44.0",
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
